/config/app.php
/config/database.php
/config/mail.php
/config/services.php
/config/cache.php
/config/session.php
/config/queue.php

# Log files
*.log
logs/
/storage/logs/laravel.log
/storage/logs/laravel-*.log

# Temporary files
*.tmp
*.temp
.tmp/
.temp/

