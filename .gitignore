# IDE and Editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.history/
*.history

# Node modules (if using npm)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Composer
composer.phar
/vendor/
homestead.json
homestead.yaml
npm-debug.log
yarn-error.log

